# =============================================================================
# Headlong Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic
# Get this from: https://console.anthropic.com → API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Supabase
# Get all of these from: Supabase Dashboard → Project Settings → API
#
# SUPABASE_ID_HEADLONG: the project ref — the subdomain in your project URL,
#   e.g. for https://abcdefghij.supabase.co the ref is "abcdefghij"
#
# SUPABASE_URL_HEADLONG: your project URL, e.g. https://abcdefghij.supabase.co
#
# SUPABASE_ANON_KEY_HEADLONG: the public anon key (safe to expose in frontend)
#
# SUPABASE_SERVICE_ROLE_KEY_HEADLONG: the secret service role key
#   (has full DB access — keep this private)
# -----------------------------------------------------------------------------
SUPABASE_ID_HEADLONG=your-project-ref
SUPABASE_URL_HEADLONG=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY_HEADLONG=eyJ...
SUPABASE_SERVICE_ROLE_KEY_HEADLONG=eyJ...

# -----------------------------------------------------------------------------
# Database connection URLs
#
# SUPABASE_DB_URL: used by the app and migration script to connect to Postgres.
#   Find this at: Supabase → Project Settings → Database → Connection Pooling
#   Use the SESSION MODE URI (port 5432) — NOT transaction mode (port 6543).
#   The direct db.<ref>.supabase.co host is disabled on newer Supabase projects.
#
#   Format: postgresql://postgres.<ref>:[db-password]@<pooler-host>:5432/postgres
#
# AGENT_REPL_DB_URL: a restricted Postgres role used by the agent's Python REPL
#   sandbox. Created by migration 003. Use the same pooler host as SUPABASE_DB_URL
#   but with agent_repl as the username and the password you set during migration.
#
#   Format: postgresql://agent_repl.<ref>:[agent_repl_password]@<pooler-host>:5432/postgres
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:[db-password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
AGENT_REPL_DB_URL=postgresql://agent_repl.your-project-ref:[agent_repl_password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Telegram (optional — enables the send_telegram_message tool)
# Create a bot at: https://t.me/BotFather
#
# TELEGRAM_BOT_TOKEN: the token BotFather gives you
#
# TELEGRAM_CHAT_ID: your personal Telegram user ID — this is the default
#   recipient when the agent sends a Telegram message. It is NOT the bot's ID.
#   Easiest way to find it: message @userinfobot on Telegram, it replies instantly.
#   You must also send /start to your bot before it can message you.
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=1234567890:AAH...
# TELEGRAM_CHAT_ID=1234567890  # your user ID, not the bot's

# -----------------------------------------------------------------------------
# Twilio SMS (optional — enables the send_sms_message tool)
# Get these from: https://console.twilio.com
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...

# -----------------------------------------------------------------------------
# SerpAPI (optional — enables the search_google tool)
# Get an API key from: https://serpapi.com
# -----------------------------------------------------------------------------
# SERPAPI_API_KEY=...

# -----------------------------------------------------------------------------
# OpenAI — required for thought embeddings and vector search
# Every thought is embedded using text-embedding-3-small so the agent can
# search its own thought history semantically via vector_search() in the REPL.
# Get an API key from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
