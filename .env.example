# =============================================================================
# Headlong Base Environment Configuration
# Copy this file to .env and fill in your values.
#
# This is the SHARED base .env — it holds infrastructure credentials used by
# all agents. Per-agent credentials (Anthropic, OpenAI, Telegram) are stored
# in .headlong/<agent-slug>/.env and set up automatically by ./headlong create.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — required, shared across all agents
# Get these from: Supabase Dashboard → Project Settings → API
#
# SUPABASE_ID_HEADLONG: your project ref — the subdomain in your project URL
#   e.g. for https://abcdefghij.supabase.co the ref is "abcdefghij"
#
# SUPABASE_URL_HEADLONG: your project URL
#
# SUPABASE_ANON_KEY_HEADLONG: the public anon key (used by the webapp)
#
# SUPABASE_SERVICE_ROLE_KEY_HEADLONG: the secret service role key
#   (has full DB access — keep this private)
# -----------------------------------------------------------------------------
SUPABASE_ID_HEADLONG=your-project-ref
SUPABASE_URL_HEADLONG=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY_HEADLONG=eyJ...
SUPABASE_SERVICE_ROLE_KEY_HEADLONG=eyJ...

# -----------------------------------------------------------------------------
# Database connection URLs — required for migrations and the agent REPL
#
# SUPABASE_DB_URL: used by scripts/run_migrations.sh and the app.
#   Find at: Supabase → Project Settings → Database → Connection Pooling
#   Use SESSION MODE (port 5432) — NOT transaction mode (port 6543).
#   The direct db.<ref>.supabase.co host is disabled on newer Supabase projects.
#
#   Format: postgresql://postgres.<ref>:[db-password]@<pooler-host>:5432/postgres
#
# AGENT_REPL_DB_URL: a restricted Postgres role used by the agent's Python REPL
#   sandbox. Created by migration 003. Same pooler host as SUPABASE_DB_URL.
#
#   Format: postgresql://agent_repl.<ref>:[agent_repl_password]@<pooler-host>:5432/postgres
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:[db-password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
AGENT_REPL_DB_URL=postgresql://agent_repl.your-project-ref:[agent_repl_password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# =============================================================================
# The variables below are PER-AGENT and normally go in .headlong/<slug>/.env,
# set up automatically by ./headlong create. You can set them here as defaults
# that all agents inherit if you only have one agent or want a shared fallback.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic — required per agent
# Get from: https://console.anthropic.com → API Keys
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# OpenAI — required per agent
# Used for thought embeddings (text-embedding-3-small) and vector search.
# Get from: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Telegram — required per agent (enables send/receive Telegram messages)
#
# TELEGRAM_BOT_TOKEN: create a bot via @BotFather on Telegram → /newbot
#
# TELEGRAM_CHAT_ID: YOUR personal Telegram user ID (not the bot's ID).
#   Find it by messaging @userinfobot on Telegram — it replies instantly.
#   You must also send /start to your bot before it can message you back.
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=1234567890:AAH...
# TELEGRAM_CHAT_ID=1234567890  # your user ID, find via @userinfobot

# -----------------------------------------------------------------------------
# SerpAPI (optional — enables the search_google tool)
# Get from: https://serpapi.com
# -----------------------------------------------------------------------------
# SERPAPI_API_KEY=...
