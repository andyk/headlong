#!/bin/bash
set -e

REPO_ROOT="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
BASE_STATEDIR="${HEADLONG_STATE_DIR:-$REPO_ROOT/.headlong}"
BASE_LOGDIR="${HEADLONG_LOG_DIR:-$REPO_ROOT/.headlong-logs}"
SERVICES=(env agent webapp)

# Default ports
ENV_PORT=8000
AGENT_PORT=8001
WEBAPP_PORT=5173

# State/log dirs are set per-agent by set_agent_dirs()
STATEDIR="$BASE_STATEDIR"
LOGDIR="$BASE_LOGDIR"

# Sanitize a name for use as a directory/slug (lowercase, spaces to hyphens, alphanumeric only)
slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-'
}

set_agent_dirs() {
  local name="$1"
  local slug
  slug=$(slugify "$name")
  STATEDIR="$BASE_STATEDIR/$slug"
  LOGDIR="$BASE_LOGDIR/$slug"
}

# Per-service pidfiles and state
pidfile_for()  { echo "$STATEDIR/$1.pid"; }
agentfile()    { echo "$STATEDIR/agent_name"; }
portsfile()    { echo "$STATEDIR/ports"; }

# --- Port collision avoidance ---

# Check if a port is available (not claimed by another agent and not in use)
find_free_port() {
  local port=$1
  local own_dir="${2:-}"  # current agent's state dir to skip

  while true; do
    local collision=false

    # Check ports claimed by other running agents
    if [ -d "$BASE_STATEDIR" ]; then
      for pf in "$BASE_STATEDIR"/*/ports; do
        [ -f "$pf" ] || continue
        # Skip our own port file
        [ "$(dirname "$pf")" = "$own_dir" ] && continue
        if grep -q "=$port$" "$pf" 2>/dev/null; then
          collision=true
          break
        fi
      done
    fi

    # Check if port is actually in use on the system
    if ! $collision; then
      if ss -tlnH 2>/dev/null | grep -q ":${port}\b" || \
         lsof -iTCP:"$port" -sTCP:LISTEN -t &>/dev/null; then
        collision=true
      fi
    fi

    if $collision; then
      port=$((port + 1))
    else
      break
    fi
  done

  echo "$port"
}

# Resolve collisions for all three port variables
resolve_port_collisions() {
  local own_dir="$1"
  local orig_env=$ENV_PORT orig_agent=$AGENT_PORT orig_webapp=$WEBAPP_PORT

  # Collect all three into a set so we also avoid self-collision
  # (e.g. if defaults were manually set to the same value)
  ENV_PORT=$(find_free_port "$ENV_PORT" "$own_dir")

  # For agent port, also avoid the just-assigned env port
  local port=$AGENT_PORT
  while true; do
    port=$(find_free_port "$port" "$own_dir")
    if [ "$port" -eq "$ENV_PORT" ]; then
      port=$((port + 1))
      continue
    fi
    break
  done
  AGENT_PORT=$port

  # For webapp port, also avoid env and agent ports
  port=$WEBAPP_PORT
  while true; do
    port=$(find_free_port "$port" "$own_dir")
    if [ "$port" -eq "$ENV_PORT" ] || [ "$port" -eq "$AGENT_PORT" ]; then
      port=$((port + 1))
      continue
    fi
    break
  done
  WEBAPP_PORT=$port

  # Notify user if any ports were changed
  if [ "$ENV_PORT" -ne "$orig_env" ] || [ "$AGENT_PORT" -ne "$orig_agent" ] || [ "$WEBAPP_PORT" -ne "$orig_webapp" ]; then
    echo "  (ports adjusted to avoid collisions: env=$ENV_PORT, agent=$AGENT_PORT, webapp=$WEBAPP_PORT)"
  fi
}

# --- Save/load ports for a running agent ---
save_ports() {
  echo "ENV_PORT=$ENV_PORT" > "$(portsfile)"
  echo "AGENT_PORT=$AGENT_PORT" >> "$(portsfile)"
  echo "WEBAPP_PORT=$WEBAPP_PORT" >> "$(portsfile)"
}

load_ports() {
  local pf
  pf=$(portsfile)
  if [ -f "$pf" ]; then
    source "$pf"
  fi
}

# --- Usage ---
usage() {
  echo "Usage: ./headlong <command> [options]"
  echo ""
  echo "Commands:"
  echo "  create <agent_name> [options]      Create a new agent (config + DB)"
  echo "  start <agent_name> [options]       Start all services"
  echo "  start <service> [options]           Start a single service (env|agent|webapp)"
  echo "  stop  [agent_name] [service]       Stop all or a single service"
  echo "  status [agent_name]                Show status of all services"
  echo "  logs  [agent_name] [service]       Tail logs (all or one service)"
  echo "  list                               List running agents"
  echo ""
  echo "Create options:"
  echo "  --anthropic-key KEY       Anthropic API key"
  echo "  --openai-key KEY          OpenAI API key"
  echo "  --supabase-url URL        Supabase project URL"
  echo "  --supabase-key KEY        Supabase service role key"
  echo "  --telegram-token TOKEN    Telegram bot token for this agent"
  echo "  --telegram-chat-id ID     Telegram chat ID for this agent"
  echo ""
  echo "Start options:"
  echo "  --no-docker               Force native mode for env daemon"
  echo "  --env-port PORT           Port for env daemon (default: 8000)"
  echo "  --agent-port PORT         Port for agent daemon (default: 8001)"
  echo "  --webapp-port PORT        Port for webapp (default: 5173)"
  echo "  --help, -h                Show this help message"
}

# --- Collect all PIDs in a process tree ---
collect_pids() {
  local pid=$1
  echo "$pid"
  local children
  children=$(pgrep -P "$pid" 2>/dev/null || true)
  for child in $children; do
    collect_pids "$child"
  done
}

# --- Check if a service is running ---
is_running() {
  local svc=$1
  local pf
  pf=$(pidfile_for "$svc")
  if [ -f "$pf" ]; then
    local pid
    pid=$(cat "$pf")
    if kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  return 1
}

# --- Source .env (base + per-agent override) ---
load_env() {
  if [ -f "$REPO_ROOT/.env" ]; then
    set -a
    source "$REPO_ROOT/.env"
    set +a
  fi
  # Per-agent overrides (STATEDIR is set by set_agent_dirs before this is called)
  local agent_env="$STATEDIR/.env"
  if [ -f "$agent_env" ]; then
    set -a
    source "$agent_env"
    set +a
  fi
}

# --- Get stored agent name ---
get_agent_name() {
  local af
  af=$(agentfile)
  if [ -f "$af" ]; then
    cat "$af"
  else
    echo ""
  fi
}

# --- Find agent state dir by name ---
find_agent_dir() {
  local name="$1"
  local slug
  slug=$(slugify "$name")
  local dir="$BASE_STATEDIR/$slug"
  if [ -d "$dir" ]; then
    echo "$dir"
  else
    echo ""
  fi
}

# --- List running agents ---
list_agents() {
  echo "=== Running Agents ==="
  local found=false
  if [ -d "$BASE_STATEDIR" ]; then
    for dir in "$BASE_STATEDIR"/*/; do
      [ -d "$dir" ] || continue
      local af="$dir/agent_name"
      if [ -f "$af" ]; then
        local name
        name=$(cat "$af")
        local running=false
        for svc in "${SERVICES[@]}"; do
          local pf="$dir/$svc.pid"
          if [ -f "$pf" ] && kill -0 "$(cat "$pf")" 2>/dev/null; then
            running=true
            break
          fi
        done
        if $running; then
          found=true
          local ports_info=""
          if [ -f "$dir/ports" ]; then
            source "$dir/ports"
            ports_info=" (env:$ENV_PORT, agent:$AGENT_PORT, webapp:$WEBAPP_PORT)"
          fi
          echo "  $name$ports_info"
        fi
      fi
    done
  fi
  if ! $found; then
    echo "  (no agents running)"
  fi
}

# --- Start a single service ---
start_service() {
  local svc=$1
  local agent_name=$2
  local no_docker=${3:-false}

  if is_running "$svc"; then
    echo "  $svc is already running (PID $(cat "$(pidfile_for "$svc")"))"
    return
  fi

  mkdir -p "$LOGDIR" "$STATEDIR"
  load_env

  case "$svc" in
    env)
      # Decide Docker vs native
      local use_docker=false
      if ! $no_docker && docker info &>/dev/null; then
        use_docker=true
      fi

      local container_name="headlong-env-$(slugify "$agent_name")"

      if $use_docker; then
        echo "  Starting env (Docker) on port $ENV_PORT..."
        docker build -q -t headlong-env "$REPO_ROOT/packages/env" >/dev/null
        docker rm -f "$container_name" 2>/dev/null || true
        docker run -d \
          --name "$container_name" \
          -e ANTHROPIC_API_KEY \
          -e SUPABASE_URL_HEADLONG \
          -e SUPABASE_SERVICE_ROLE_KEY_HEADLONG \
          -e TELEGRAM_BOT_TOKEN \
          -e TELEGRAM_CHAT_ID \
          -e SERPAPI_API_KEY \
          -e OPENAI_API_KEY \
          -e HEADLONG_ENV_PORT=8000 \
          -p "$ENV_PORT":8000 \
          -v "$REPO_ROOT":/app/headlong \
          -w /app/headlong/packages/env \
          headlong-env \
          "$agent_name" >/dev/null
        docker logs -f "$container_name" >> "$LOGDIR/env.log" 2>&1 &
        echo $! > "$(pidfile_for env)"
      else
        echo "  Starting env (native) on port $ENV_PORT..."
        (
          cd "$REPO_ROOT/packages/env"
          source venv/bin/activate
          HEADLONG_ENV_PORT="$ENV_PORT" python main.py "$agent_name"
        ) >> "$LOGDIR/env.log" 2>&1 &
        echo $! > "$(pidfile_for env)"
      fi
      ;;

    agent)
      echo "  Starting agent on port $AGENT_PORT..."
      (
        cd "$REPO_ROOT/packages/agent"
        source venv/bin/activate
        HEADLONG_AGENT_PORT="$AGENT_PORT" python main.py "$agent_name"
      ) >> "$LOGDIR/agent.log" 2>&1 &
      echo $! > "$(pidfile_for agent)"
      ;;

    webapp)
      echo "  Starting webapp on port $WEBAPP_PORT..."
      (
        cd "$REPO_ROOT/packages/webapp"
        VITE_ENV_PORT="$ENV_PORT" VITE_AGENT_PORT="$AGENT_PORT" npm run dev -- --port "$WEBAPP_PORT"
      ) >> "$LOGDIR/webapp.log" 2>&1 &
      echo $! > "$(pidfile_for webapp)"
      ;;

    *)
      echo "Unknown service: $svc"
      exit 1
      ;;
  esac
}

# --- Stop a single service ---
stop_service() {
  local svc=$1
  local pf
  pf=$(pidfile_for "$svc")

  if [ ! -f "$pf" ]; then
    # Try killing by port as fallback
    local port
    case "$svc" in
      env)    port=$ENV_PORT ;;
      agent)  port=$AGENT_PORT ;;
      webapp) port=$WEBAPP_PORT ;;
    esac
    local port_pid
    port_pid=$(lsof -ti:"$port" 2>/dev/null | head -1)
    if [ -n "$port_pid" ]; then
      echo "  Stopping $svc (port $port, PID $port_pid)..."
      kill "$port_pid" 2>/dev/null || true
      sleep 1
      kill -9 "$port_pid" 2>/dev/null || true
    else
      echo "  $svc is not running"
    fi
    return
  fi

  local pid
  pid=$(cat "$pf")
  echo "  Stopping $svc (PID $pid)..."

  # Collect full process tree
  local all_pids=()
  while IFS= read -r p; do
    all_pids+=("$p")
  done < <(collect_pids "$pid")

  # SIGTERM
  for p in "${all_pids[@]}"; do
    kill "$p" 2>/dev/null || true
  done

  sleep 1

  # SIGKILL survivors
  for p in "${all_pids[@]}"; do
    if kill -0 "$p" 2>/dev/null; then
      kill -9 "$p" 2>/dev/null || true
    fi
  done

  rm -f "$pf"

  # Clean up Docker container for env
  if [ "$svc" = "env" ]; then
    local agent_name
    agent_name=$(get_agent_name)
    local container_name="headlong-env-$(slugify "$agent_name")"
    docker rm -f "$container_name" 2>/dev/null || true
  fi
}

# --- Start command ---
do_start() {
  local agent_name=""
  local no_docker=false
  local target_service=""
  local args=("$@")
  local i=0

  while [ $i -lt ${#args[@]} ]; do
    case "${args[$i]}" in
      --no-docker) no_docker=true ;;
      --env-port)
        i=$((i + 1)); ENV_PORT="${args[$i]}" ;;
      --agent-port)
        i=$((i + 1)); AGENT_PORT="${args[$i]}" ;;
      --webapp-port)
        i=$((i + 1)); WEBAPP_PORT="${args[$i]}" ;;
      env|agent|webapp)
        target_service="${args[$i]}" ;;
      *)
        agent_name="${args[$i]}" ;;
    esac
    i=$((i + 1))
  done

  # Starting a single service
  if [ -n "$target_service" ]; then
    # Need agent name for env and agent services
    if [ "$target_service" != "webapp" ]; then
      if [ -z "$agent_name" ]; then
        agent_name=$(get_agent_name)
      fi
      if [ -z "$agent_name" ]; then
        echo "No agent name found. Run './headlong start <agent_name>' first, or pass one now."
        exit 1
      fi
    fi
    set_agent_dirs "$agent_name"
    load_ports
    start_service "$target_service" "$agent_name" "$no_docker"
    return
  fi

  # Starting all services — agent name required
  if [ -z "$agent_name" ]; then
    agent_name=$(get_agent_name)
  fi
  if [ -z "$agent_name" ]; then
    echo "Usage: ./headlong start <agent_name> [--no-docker] [--env-port PORT] [--agent-port PORT] [--webapp-port PORT]"
    echo "Example: ./headlong start \"Bobby Wilder\""
    echo "Example: ./headlong start \"Alice\" --env-port 8010 --agent-port 8011 --webapp-port 5174"
    exit 1
  fi

  # Namespace state and logs by agent name
  set_agent_dirs "$agent_name"

  # Save agent name and ports for future single-service starts
  mkdir -p "$STATEDIR"
  echo "$agent_name" > "$(agentfile)"
  resolve_port_collisions "$STATEDIR"
  save_ports

  # Clear logs on full start
  rm -rf "$LOGDIR"
  mkdir -p "$LOGDIR"

  echo "Starting Headlong for $agent_name..."
  for svc in "${SERVICES[@]}"; do
    start_service "$svc" "$agent_name" "$no_docker"
  done

  echo ""
  echo "=== Headlong is running ==="
  echo "  Agent:   $agent_name"
  echo "  Env:     http://localhost:$ENV_PORT"
  echo "  Agent:   http://localhost:$AGENT_PORT"
  echo "  Webapp:  http://localhost:$WEBAPP_PORT"
  echo ""
  echo "Run './headlong logs $agent_name' to tail output, './headlong stop $agent_name' to shut down."
}

# --- Stop command ---
do_stop() {
  local agent_name=""
  local target_service=""

  for arg in "$@"; do
    case "$arg" in
      env|agent|webapp) target_service="$arg" ;;
      *) agent_name="$arg" ;;
    esac
  done

  # If agent name given, namespace to that agent
  if [ -n "$agent_name" ]; then
    set_agent_dirs "$agent_name"
    load_ports
  else
    # If no agent name, try to find the only running agent
    local count=0
    local found_dir=""
    if [ -d "$BASE_STATEDIR" ]; then
      for dir in "$BASE_STATEDIR"/*/; do
        [ -d "$dir" ] || continue
        if [ -f "$dir/agent_name" ]; then
          for svc in "${SERVICES[@]}"; do
            if [ -f "$dir/$svc.pid" ] && kill -0 "$(cat "$dir/$svc.pid")" 2>/dev/null; then
              count=$((count + 1))
              found_dir="$dir"
              break
            fi
          done
        fi
      done
    fi
    if [ "$count" -gt 1 ]; then
      echo "Multiple agents running. Specify which to stop:"
      list_agents
      exit 1
    elif [ "$count" -eq 1 ] && [ -n "$found_dir" ]; then
      STATEDIR="$found_dir"
      LOGDIR="$BASE_LOGDIR/$(basename "$found_dir")"
      agent_name=$(cat "$found_dir/agent_name")
      load_ports
    fi
  fi

  if [ -n "$target_service" ]; then
    stop_service "$target_service"
    return
  fi

  echo "Stopping Headlong${agent_name:+ for $agent_name}..."
  for svc in "${SERVICES[@]}"; do
    stop_service "$svc"
  done
  echo "All services stopped."
}

# --- Logs command ---
do_logs() {
  local agent_name=""
  local target_service=""

  for arg in "$@"; do
    case "$arg" in
      env|agent|webapp) target_service="$arg" ;;
      *) agent_name="$arg" ;;
    esac
  done

  if [ -n "$agent_name" ]; then
    set_agent_dirs "$agent_name"
  fi

  if [ ! -d "$LOGDIR" ]; then
    echo "No logs found. Is Headlong running?"
    exit 1
  fi

  if [ -n "$target_service" ]; then
    local logfile="$LOGDIR/$target_service.log"
    if [ -f "$logfile" ]; then
      tail -f "$logfile"
    else
      echo "No log file for $target_service"
      exit 1
    fi
  else
    tail -f "$LOGDIR"/*.log
  fi
}

# --- Status command ---
do_status() {
  local agent_name="${1:-}"

  if [ -n "$agent_name" ]; then
    set_agent_dirs "$agent_name"
    load_ports
  fi

  echo "=== Headlong Status ==="
  echo ""

  local stored_name
  stored_name=$(get_agent_name)
  if [ -n "$stored_name" ]; then
    echo "  Agent name: $stored_name"
    echo ""
  fi

  echo "  Services:"
  for svc in "${SERVICES[@]}"; do
    local port
    case "$svc" in
      env)    port=$ENV_PORT ;;
      agent)  port=$AGENT_PORT ;;
      webapp) port=$WEBAPP_PORT ;;
    esac

    local pf_pid="" port_pid="" status_icon status_detail
    pf=$(pidfile_for "$svc")
    if [ -f "$pf" ]; then
      pf_pid=$(cat "$pf")
      if ! kill -0 "$pf_pid" 2>/dev/null; then
        pf_pid=""
      fi
    fi
    port_pid=$(lsof -ti:"$port" 2>/dev/null | head -1)

    if [ -n "$port_pid" ]; then
      status_icon="✓"
      status_detail="http://localhost:$port  (PID $port_pid)"
    elif [ -n "$pf_pid" ]; then
      status_icon="~"
      status_detail="PID $pf_pid (not yet listening on port $port)"
    else
      status_icon="✗"
      status_detail="not running"
    fi

    printf "    %s %-8s %s\n" "$status_icon" "$svc" "$status_detail"
  done
  echo ""

  # Docker container
  local container_name="headlong-env-$(slugify "$stored_name")"
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${container_name}$"; then
    echo "  Docker:  $container_name container running"
  fi

  # Agent API live info
  local agent_api_status
  agent_api_status=$(curl -s --max-time 2 "http://localhost:$AGENT_PORT/agent/status" 2>/dev/null || true)
  if [ -n "$agent_api_status" ]; then
    local api_name uptime
    api_name=$(echo "$agent_api_status" | python3 -c "import sys,json; print(json.load(sys.stdin).get('agent_name',''))" 2>/dev/null || true)
    uptime=$(echo "$agent_api_status" | python3 -c "import sys,json; print(json.load(sys.stdin).get('uptime_seconds',0))" 2>/dev/null || true)
    if [ -n "$api_name" ]; then
      echo "  Agent:   $api_name (uptime ${uptime}s)"
    fi
  fi

  local loop_status
  loop_status=$(curl -s --max-time 2 "http://localhost:$AGENT_PORT/loop/status" 2>/dev/null || true)
  if [ -n "$loop_status" ]; then
    local running
    running=$(echo "$loop_status" | python3 -c "import sys,json; print(json.load(sys.stdin).get('running',False))" 2>/dev/null || true)
    if [ "$running" = "True" ]; then
      echo "  Loop:    running"
    else
      echo "  Loop:    stopped"
    fi
  fi
}

# --- Create command ---
do_create() {
  local agent_name=""
  local telegram_token=""
  local telegram_chat_id=""
  local openai_key=""
  local anthropic_key=""
  local supabase_url=""
  local supabase_key=""
  local args=("$@")
  local i=0

  while [ $i -lt ${#args[@]} ]; do
    case "${args[$i]}" in
      --telegram-token)
        i=$((i + 1)); telegram_token="${args[$i]}" ;;
      --telegram-chat-id)
        i=$((i + 1)); telegram_chat_id="${args[$i]}" ;;
      --openai-key)
        i=$((i + 1)); openai_key="${args[$i]}" ;;
      --anthropic-key)
        i=$((i + 1)); anthropic_key="${args[$i]}" ;;
      --supabase-url)
        i=$((i + 1)); supabase_url="${args[$i]}" ;;
      --supabase-key)
        i=$((i + 1)); supabase_key="${args[$i]}" ;;
      *)
        agent_name="${args[$i]}" ;;
    esac
    i=$((i + 1))
  done

  if [ -z "$agent_name" ]; then
    echo "Usage: ./headlong create <agent_name> [options]"
    echo ""
    echo "Options:"
    echo "  --anthropic-key KEY       Anthropic API key"
    echo "  --openai-key KEY          OpenAI API key"
    echo "  --supabase-url URL        Supabase project URL"
    echo "  --supabase-key KEY        Supabase service role key"
    echo "  --telegram-token TOKEN    Telegram bot token"
    echo "  --telegram-chat-id ID     Telegram chat ID"
    exit 1
  fi

  local slug
  slug=$(slugify "$agent_name")
  local agent_dir="$BASE_STATEDIR/$slug"

  echo ""
  echo "Creating agent: $agent_name (slug: $slug)"
  echo ""

  # Create agent directory
  mkdir -p "$agent_dir"
  echo "$agent_name" > "$agent_dir/agent_name"

  # Load base env for current values
  if [ -f "$REPO_ROOT/.env" ]; then
    set -a
    source "$REPO_ROOT/.env"
    set +a
  else
    echo "  Note: no .env found at $REPO_ROOT/.env"
  fi

  # --- Required credentials (written to base .env if missing) ---
  # These are shared infra secrets needed by all agents.

  # Apply any flag values for required credentials
  [ -n "$supabase_url" ] && SUPABASE_URL_HEADLONG="$supabase_url"
  [ -n "$supabase_key" ] && SUPABASE_SERVICE_ROLE_KEY_HEADLONG="$supabase_key"

  local base_env_changed=false

  # Helper: prompt for a required var if missing, write to base .env
  require_var() {
    local var_name="$1" label="$2" flag_name="$3"
    local current="${!var_name}"
    if [ -n "$current" ]; then
      return
    fi
    if [ -t 0 ]; then
      read -rp "  $label: " new_val
      if [ -z "$new_val" ]; then
        echo "  ERROR: $var_name is required."
        exit 1
      fi
      eval "export $var_name=\"\$new_val\""
      echo "$var_name=$new_val" >> "$REPO_ROOT/.env"
      base_env_changed=true
    else
      echo "ERROR: $var_name is required. Pass $flag_name or set it in .env"
      exit 1
    fi
  }

  echo "Checking required credentials..."
  require_var SUPABASE_URL_HEADLONG "Supabase project URL (e.g. https://xyz.supabase.co)" "--supabase-url"
  require_var SUPABASE_SERVICE_ROLE_KEY_HEADLONG "Supabase service role key" "--supabase-key"

  if $base_env_changed; then
    echo "  Saved to $REPO_ROOT/.env"
  else
    echo "  All required credentials found."
  fi
  echo ""

  # --- Per-agent credentials (written to agent .env) ---
  # Required: Anthropic, OpenAI, Telegram. If already in base .env they're
  # inherited, but new values go into the agent-specific .env.
  local agent_env_contents=""

  add_agent_var() {
    local var_name="$1" value="$2"
    if [ -n "$value" ]; then
      agent_env_contents+="$var_name=$value"$'\n'
      eval "export $var_name=\"\$value\""
    fi
  }

  # Helper: ensure a per-agent var has a value. Checks: flag > base .env > prompt.
  # New values are written to the agent .env, not the base .env.
  require_agent_var() {
    local var_name="$1" label="$2" flag_name="$3" flag_val="$4"
    # Flag value takes priority
    if [ -n "$flag_val" ]; then
      add_agent_var "$var_name" "$flag_val"
      return
    fi
    # Already in environment (from base .env)
    local current="${!var_name}"
    if [ -n "$current" ]; then
      return
    fi
    # Prompt interactively
    if [ -t 0 ]; then
      read -rp "  $label: " new_val
      if [ -z "$new_val" ]; then
        echo "  ERROR: $var_name is required."
        exit 1
      fi
      add_agent_var "$var_name" "$new_val"
    else
      echo "ERROR: $var_name is required. Pass $flag_name or set it in .env"
      exit 1
    fi
  }

  echo "Agent credentials (values not in .env will be saved to $agent_dir/.env):"
  require_agent_var ANTHROPIC_API_KEY "Anthropic API key" "--anthropic-key" "$anthropic_key"
  require_agent_var OPENAI_API_KEY "OpenAI API key" "--openai-key" "$openai_key"
  require_agent_var TELEGRAM_BOT_TOKEN "Telegram bot token" "--telegram-token" "$telegram_token"
  require_agent_var TELEGRAM_CHAT_ID "Telegram chat ID" "--telegram-chat-id" "$telegram_chat_id"
  echo ""

  # --- Optional per-agent overrides ---
  if [ -t 0 ]; then
    echo "Optional overrides (Enter to skip):"
    local optional_vars=(SERPAPI_API_KEY)
    for var in "${optional_vars[@]}"; do
      local current="${!var}"
      local display="(not set)"
      if [ -n "$current" ]; then
        if [ ${#current} -gt 8 ]; then
          display="****${current: -4}"
        else
          display="****"
        fi
      fi
      read -rp "  $var [$display]: " new_val
      add_agent_var "$var" "$new_val"
    done
    echo ""
  fi

  if [ -n "$agent_env_contents" ]; then
    printf "%s" "$agent_env_contents" > "$agent_dir/.env"
    echo "Saved agent secrets to $agent_dir/.env"
  else
    echo "All credentials inherited from base .env."
  fi

  # Set up env loading for the DB insertion
  set_agent_dirs "$agent_name"
  load_env

  # Insert agent + environment rows into Supabase
  echo ""
  echo "Inserting agent + environment into Supabase..."

  "$REPO_ROOT/packages/agent/venv/bin/python" - "$agent_name" "$REPO_ROOT" <<'PYEOF'
import sys, os

agent_name = sys.argv[1]
repo_root = sys.argv[2]

url = os.environ.get("SUPABASE_URL_HEADLONG")
key = os.environ.get("SUPABASE_SERVICE_ROLE_KEY_HEADLONG")
if not url or not key:
    print("  ERROR: SUPABASE_URL_HEADLONG and SUPABASE_SERVICE_ROLE_KEY_HEADLONG must be set in .env")
    sys.exit(1)

from supabase import create_client
sb = create_client(url, key)

# Default agent system prompt (RLM with REPL)
agent_prompt = f"""You are the subconscious mind of {agent_name}.

You have a Python REPL available. Write code in ```repl blocks to query the database,
analyze patterns, build memories, and reason iteratively before producing your thought.

## CRITICAL RULE: Query first, then FINAL in a SEPARATE response.

**Step 1 (first response):** Write ONLY ONE ```repl block that queries and prints recent
thoughts. Do NOT call FINAL() in this response.

```repl
recent = sql("SELECT body FROM thoughts WHERE agent_name = %s ORDER BY index DESC LIMIT 15", [agent_name])
for t in recent[::-1]:
    print(t["body"][:300])
    print("---")
```

**Step 2 (second response):** Now that you've READ the actual thoughts, call FINAL() with
a thought that directly continues from what you just read.

## Available REPL functions

- `sql(query, params=None)` -- Execute SQL against the database.
- `llm_query(prompt, max_tokens=1024)` -- Call a sub-LLM for analysis.
- `embed(text)` -- Get a vector embedding. Returns list of floats.
- `vector_search(query_text, limit=10)` -- Search memories by similarity.
- `print(...)` -- Output returned to you as REPL output.
- `agent_name` -- String variable with the current agent's name.

When ready, call `FINAL("your thought")` or `FINAL_VAR("var_name")`.
"""

# Default environment system prompt (action selection)
env_prompt = """Your job is to consider your recent thoughts and then take an action.
The way you take action is by calling one of the available tools with appropriate arguments.
If you don't think any tool is appropriate for this action, respond with text starting with "observation: " explaining what you observe.
When deciding what action to take, use the following stream of recent thoughts for context."""

sb.table("agents").upsert({
    "name": agent_name,
    "system_prompt": agent_prompt,
    "config": {},
}).execute()
print("  agents row: OK")

sb.table("environments").upsert({
    "name": agent_name,
    "system_prompt": env_prompt,
    "config": {},
}).execute()
print("  environments row: OK")

# Seed first 15 thoughts from Bobby Wilder
source_agent = "Bobby Wilder"
result = (
    sb.table("thoughts")
    .select("body")
    .eq("agent_name", source_agent)
    .order("index", desc=False)
    .limit(15)
    .execute()
)

if result.data:
    rows = []
    for i, row in enumerate(result.data):
        rows.append({
            "agent_name": agent_name,
            "body": row["body"],
            "index": float(i + 1),
            "metadata": {"seeded": True, "source": source_agent},
            "created_by": "user",
        })
    sb.table("thoughts").insert(rows).execute()
    print(f"  seeded {len(rows)} starter thoughts (copied from {source_agent})")
else:
    print(f"  warning: no thoughts found for {source_agent}, skipping seed")
PYEOF

  echo ""
  echo "Agent \"$agent_name\" is ready. Start with:"
  echo "  ./headlong start \"$agent_name\""
}

